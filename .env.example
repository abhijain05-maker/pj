################################################################################
# Route Mate — environment variables
#
# Copy this file to `.env` (for local dev) and configure the same variables in
# your hosting providers (Netlify for the frontend, your backend host for the
# API server).
################################################################################

# ─── BACKEND (api-server) ─────────────────────────────────────────────────────
# Required: PostgreSQL connection string used by Drizzle.
# For Supabase use the Connection Pooler (Transaction mode) string from
# Project Settings → Database → Connection string.
# Example:
# db_url=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
db_url=

# Required: random string used to sign Express sessions.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Optional: port the API server should listen on.
# Most hosts (Render, Railway, Fly, Replit) inject PORT automatically — leave blank.
PORT=

# Optional: lock CORS to your Netlify site once the frontend is deployed.
# Example: https://route-mate.netlify.app
CORS_ORIGIN=

# ─── FRONTEND (school-bus, built by Netlify) ──────────────────────────────────
# Required for Netlify: absolute URL of your deployed API server.
# All `/api/...` calls from the frontend are prefixed with this.
# Example: https://route-mate-api.onrender.com
VITE_API_URL=

# Required by the Vite build (Netlify sets this in netlify.toml — only override
# if you serve the app from a sub-path).
BASE_PATH=/

# ─── ADMIN LOGIN (frontend, hardcoded) ────────────────────────────────────────
# These are baked into the React app (`src/hooks/use-auth.tsx`); change the
# constants there if you want different credentials.
#   Username: admin
#   Password: GyanFactory
